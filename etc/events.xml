<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="controller_action_predispatch_customer_account_login">
        <observer name="m2oidc_customer_auto_redirect"
                  instance="M2Oidc\OAuth\Observer\CustomerLoginAutoRedirectObserver" />
    </event>

    <!-- OIDC JIT provisioning hooks — third-party modules may observe these events.
         All events carry a DataObject transport; set 'skip_creation' => true on
         before-events to abort user creation and return null. -->
    <event name="customer_delete_after">
        <observer name="m2oidc_customer_delete"
                  instance="M2Oidc\OAuth\Observer\CustomerDeleteObserver"/>
    </event>

    <event name="admin_user_delete_after">
        <observer name="m2oidc_admin_user_delete"
                  instance="M2Oidc\OAuth\Observer\AdminUserDeleteObserver"/>
    </event>

    <event name="oidc_customer_before_create">
        <!-- No built-in observers; dispatched so third-party modules can intercept. -->
    </event>
    <event name="oidc_customer_after_create">
        <!-- No built-in observers; dispatched so third-party modules can react. -->
    </event>
    <event name="oidc_admin_user_before_create">
        <!-- No built-in observers; dispatched so third-party modules can intercept. -->
    </event>
    <event name="oidc_admin_user_after_create">
        <!-- No built-in observers; dispatched so third-party modules can react. -->
    </event>

    <!-- Fired after all OIDC claims have been mapped to Magento attributes.
         Transport keys: provider_id (int), mapped_attrs (DataObject — writable),
         raw_claims (DataObject — read-only snapshot of the raw OIDC response).
         Observers may call mapped_attrs->setData() to alter attribute values
         before user creation / profile sync. -->
    <event name="oidc_after_attribute_mapping">
        <!-- No built-in observers; dispatched so third-party modules can alter mapped attributes. -->
    </event>
</config>
