<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">

    <!-- invoked before every adminhtml controller -->
    <event name="controller_action_predispatch">
        <observer name="oauth_observer"
                  instance="MiniOrange\OAuth\Observer\OAuthObserver" />
    </event>

    <!-- auto-redirect on admin login page -->
    <event name="controller_action_predispatch_adminhtml_auth_login">
        <observer name="mooauth_admin_auto_redirect"
                  instance="MiniOrange\OAuth\Observer\AdminLoginAutoRedirectObserver" />
    </event>
</config>
