<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">

    <!-- invoked before every adminhtml controller -->
    <event name="controller_action_predispatch">
        <observer name="oauth_observer"
                  instance="M2Oidc\OAuth\Observer\OAuthObserver" />
        <observer name="m2oidc_admin_token_auto_refresh"
                  instance="M2Oidc\OAuth\Observer\AdminTokenAutoRefreshObserver" />
    </event>

    <!-- auto-redirect on admin login page -->
    <event name="controller_action_predispatch_adminhtml_auth_login">
        <observer name="m2oidc_admin_auto_redirect"
                  instance="M2Oidc\OAuth\Observer\AdminLoginAutoRedirectObserver" />
    </event>

    <event name="adminhtml_user_logout">
        <observer name="m2oidc_admin_set_logout_flag"
                  instance="M2Oidc\OAuth\Observer\AdminSetLogoutFlagObserver"/>
    </event>

    <!-- OIDC JIT provisioning hooks — third-party modules may observe these events.
         All events carry a DataObject transport; set 'skip_creation' => true on
         before-events to abort user creation and return null. -->
    <event name="oidc_admin_user_before_create">
        <!-- No built-in observers; dispatched so third-party modules can intercept. -->
    </event>
    <event name="oidc_admin_user_after_create">
        <!-- No built-in observers; dispatched so third-party modules can react. -->
    </event>
    <event name="oidc_customer_before_create">
        <!-- No built-in observers; dispatched so third-party modules can intercept. -->
    </event>
    <event name="oidc_customer_after_create">
        <!-- No built-in observers; dispatched so third-party modules can react. -->
    </event>

</config>
