<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
   <table name="m2oidc_oauth_client_apps" resource="default" engine="innodb" comment="Miniorange OAuth Client Apps">
      <column xsi:type="smallint" name="id" padding="7" unsigned="true" nullable="false" identity="true" comment="ID" />
      <column xsi:type="text" name="app_name" nullable="false" comment="The type of app" />
      <column xsi:type="text" name="callback_uri" nullable="false" comment="The callback uri of the Provider" />
      <column xsi:type="text" name="clientID" nullable="false" comment="The client ID of the Provider" />
      <column xsi:type="text" name="client_secret" nullable="true" comment="The client secret of the Provider (null for public clients)" />
      <column xsi:type="text" name="scope" nullable="false" comment="The scope of the Provider" />
      <column xsi:type="text" name="endsession_endpoint" nullable="false" comment="The endsession endpoint" />
      <column xsi:type="text" name="revocation_endpoint" nullable="true" comment="RFC 7009 token revocation endpoint (optional)" />
      <column xsi:type="text" name="authorize_endpoint" nullable="false" comment="The authorize endpoint" />
      <column xsi:type="text" name="access_token_endpoint" nullable="false" comment="The token endpoint" />
      <column xsi:type="text" name="user_info_endpoint" nullable="false" comment="The user info endpoint" />
      <column xsi:type="text" name="jwks_endpoint" nullable="false" comment="The JWKS endpoint" />
      <column xsi:type="text" name="values_in_header" nullable="false" comment="Send values in header" />
      <column xsi:type="text" name="values_in_body" nullable="false" comment="Send values in body" />
      <column xsi:type="text" name="grant_type" nullable="false" comment="Grant Type Selected" />
      <column xsi:type="text" name="pkce_flow" nullable="false" comment="PKCE flow" />
      <column xsi:type="smallint" name="public_client" padding="1" unsigned="true" nullable="false" default="0" comment="1 = public client (no client secret, RFC 6749 §2.1); 0 = confidential client" />
      <column xsi:type="text" name="well_known_config_url" nullable="false" comment="Well Known Config URL" />
      <column xsi:type="text" name="issuer" nullable="false" comment="OIDC Issuer from discovery document" />
      <!-- Attribute mapping columns — nullable after Phase 4 normalization; rows use m2oidc_oauth_attribute_mappings -->
      <column xsi:type="text" name="email_attribute" nullable="true" comment="The email attribute of the provider" />
      <column xsi:type="text" name="username_attribute" nullable="true" comment="The username attribute of the provider" />
      <column xsi:type="text" name="firstname_attribute" nullable="true" comment="The first name attribute of the provider" />
      <column xsi:type="text" name="lastname_attribute" nullable="true" comment="The Last name attribute of the provider" />
      <column xsi:type="text" name="group_attribute" nullable="true" comment="The group name attribute" />
      <column xsi:type="text" name="billing_city_attribute" nullable="true" comment="The billing_city attribute" />
      <column xsi:type="text" name="billing_state_attribute" nullable="true" comment="The billing_state attribute" />
      <column xsi:type="text" name="billing_country_attribute" nullable="true" comment="The billing_country attribute" />
      <column xsi:type="text" name="billing_address_attribute" nullable="true" comment="The billing_address attribute" />
      <column xsi:type="text" name="billing_phone_attribute" nullable="true" comment="The billing_Telephone attribute" />
      <column xsi:type="text" name="billing_zip_attribute" nullable="true" comment="The billing_zip code attribute" />

      <!-- Role/group mapping columns — nullable after Phase 4; rows use m2oidc_oauth_role_mappings -->
      <column xsi:type="text" name="default_group" nullable="true" comment="Default Group for Frontend Users" />
      <column xsi:type="text" name="default_role" nullable="true" comment="Default Role for Backend Users" />
      <column xsi:type="text" name="oauth_customer_group_mapping" nullable="true" comment="Group Mapping for Frontend Users" />
      <column xsi:type="text" name="oauth_admin_role_mapping" nullable="true" comment="Role Mapping for Backend Users" />
      <column xsi:type="text" name="m2oidc_auto_create_customer" nullable="false" comment="Auto create Customer" />
      <column xsi:type="text" name="m2oidc_auto_create_admin" nullable="false" comment="Auto create Admin" />
      <column xsi:type="text" name="show_customer_link" nullable="false" comment="Show Customer SSO Link" />
      <column xsi:type="text" name="show_admin_link" nullable="false" comment="Show Admin SSO Link" />
      <column xsi:type="text" name="autoredirect_admin" nullable="false" comment="Auto redirect admins from login page to IdP" />
      <column xsi:type="text" name="autoredirect_customer" nullable="false" comment="Auto redirect customers from login page to IdP" />
      <column xsi:type="smallint" name="idp_initiated_enabled" padding="1" unsigned="true" nullable="false" default="0" comment="Allow IdP-initiated SSO (OIDC Third-Party Initiated Login §4). 0=disabled, 1=enabled." />

      <!-- Per-provider: sync existing user data from OIDC on every SSO login -->
      <column xsi:type="smallint" name="sync_customer_profile_on_sso" nullable="false" default="0" comment="Sync customer name, DOB, gender from OIDC on every login" />
      <column xsi:type="smallint" name="sync_customer_address_on_sso" nullable="false" default="0" comment="Sync customer billing/shipping address from OIDC on every login" />
      <column xsi:type="smallint" name="sync_customer_group_on_sso" nullable="false" default="0" comment="Re-evaluate customer group from OIDC on every login" />
      <column xsi:type="smallint" name="sync_admin_profile_on_sso" nullable="false" default="0" comment="Sync admin name and username from OIDC on every login" />
      <column xsi:type="smallint" name="sync_admin_role_on_sso" nullable="false" default="0" comment="Re-evaluate admin role from OIDC on every login" />
      
      <!-- Per-provider login options -->
      <column xsi:type="text" name="dob_attribute" nullable="true" comment="OIDC claim name for date of birth" />
      <column xsi:type="text" name="gender_attribute" nullable="true" comment="OIDC claim name for gender" />
      <column xsi:type="text" name="m2oidc_disable_non_oidc_admin_login" nullable="false" default="0" comment="Block non-OIDC admin login for this provider (1=enabled)" />
      <column xsi:type="text" name="m2oidc_disable_non_oidc_customer_login" nullable="false" default="0" comment="Block non-OIDC customer login for this provider (1=enabled)" />

      <!-- Multi-provider support columns -->
      <column xsi:type="varchar" name="display_name" length="255" nullable="true" comment="Human-readable provider label (e.g. Okta, Google)" />
      <column xsi:type="smallint" name="is_active" padding="1" unsigned="true" nullable="false" default="1" comment="Enable (1) or disable (0) this provider" />
      <column xsi:type="varchar" name="login_type" length="20" nullable="false" default="customer" comment="Login scope: customer | admin | both" />
      <column xsi:type="smallint" name="sort_order" padding="5" unsigned="true" nullable="false" default="0" comment="Display order for SSO buttons (lower = first)" />
      <column xsi:type="varchar" name="button_label" length="100" nullable="true" comment="Override text shown on the SSO button" />
      <column xsi:type="varchar" name="button_color" length="7" nullable="true" comment="Hex colour for SSO button (#rrggbb)" />

      <!-- Last test result tracking -->
      <column xsi:type="varchar" name="last_test_status" length="20" nullable="true" comment="Status of last test run: success, failed, or unsuccessful" />
      <column xsi:type="datetime" name="last_test_at" nullable="true" comment="Timestamp of the last test run" />

      <!-- Received OIDC claims from test configuration (per-provider) -->
      <column xsi:type="text" name="received_oidc_claims" nullable="true" comment="JSON array of OIDC claim keys received during last test (per-provider)" />

      <!-- Claim value encoding: how to decode raw claim values before attribute mapping.
           none   = no decoding (default)
           base64 = Base64-decode each leaf value (and key) in the flattened claim set;
                    invalid base64 strings are left as-is (strict mode, must be valid UTF-8) -->
      <column xsi:type="varchar" name="claim_encoding" length="20" nullable="false" default="none"
              comment="Claim value encoding: none | base64" />

      <!-- JWKS cache TTL in seconds. Default 86400 (24 h). Reduce for faster key-rotation response.
           0 or NULL falls back to the 86400 default. -->
      <column xsi:type="int" name="jwks_cache_ttl" nullable="true" default="86400"
              comment="JWKS public-key cache lifetime in seconds (default 86400)" />

      <!-- Per-provider HTTP connect/read timeout in seconds. Reduce for faster failure detection
           on slow IdPs. Min 5 s recommended; 0 falls back to the 30 s default. -->
      <column xsi:type="smallint" name="http_timeout" nullable="false" default="30"
              comment="Per-provider HTTP timeout in seconds (default: 30)" />

      <column xsi:type="varchar" name="log_file_suffix" length="64" nullable="true"
              comment="Optional log file suffix. When set, this provider logs to var/log/M2Oidc_&lt;suffix&gt;.log instead of the shared M2Oidc.log. Use only letters, digits, and underscores." />

      <column xsi:type="smallint" name="headless_mode" padding="1" unsigned="true" nullable="false" default="0"
              comment="Enable Headless / PWA mode. When 1, the OIDC flow returns a customer token via postMessage instead of a session cookie." />

      <constraint xsi:type="primary" referenceId="PRIMARY">
         <column name="id" />
      </constraint>

      <!-- Index for active-provider queries (getAllActiveProviders) -->
      <index referenceId="M2OIDC_OAUTH_CLIENT_APPS_IS_ACTIVE_LOGIN_TYPE" indexType="btree">
         <column name="is_active" />
         <column name="login_type" />
         <column name="sort_order" />
      </index>
   </table>

   <!-- Normalized attribute mapping table (Phase 4).
        One row per provider × attribute type.
        attribute_type: 'email'|'username'|'firstname'|'lastname'|'group'|'dob'|'gender'|
                        'billing_city'|'billing_state'|'billing_country'|'billing_address'|
                        'billing_phone'|'billing_zip'
        attribute_name: the OIDC claim key (e.g. 'email', 'given_name', 'custom:dept')
        sync_on_sso: 1 = re-sync this attribute from OIDC on every login -->
   <table name="m2oidc_oauth_attribute_mappings" resource="default" engine="innodb"
          comment="Normalized OIDC attribute mappings per provider">
      <column xsi:type="int" name="id" padding="10" unsigned="true" nullable="false"
              identity="true" comment="Row ID"/>
      <column xsi:type="smallint" name="provider_id" padding="7" unsigned="true" nullable="false"
              comment="OIDC Provider ID (FK to m2oidc_oauth_client_apps.id)"/>
      <column xsi:type="varchar" name="attribute_type" length="30" nullable="false"
              comment="Attribute slot: email, firstname, billing_city, etc."/>
      <column xsi:type="varchar" name="attribute_name" length="255" nullable="false"
              comment="OIDC claim key configured by the admin"/>
      <column xsi:type="smallint" name="sync_on_sso" padding="1" unsigned="true" nullable="false"
              default="0" comment="1 = re-sync this attribute from OIDC on every SSO login"/>
      <column xsi:type="varchar" name="transform_function" length="32" nullable="true"
              comment="Optional transform function: concat | split | prefix | regex_replace (NULL = passthrough)"/>
      <column xsi:type="varchar" name="transform_params" length="255" nullable="true"
              comment="JSON-encoded parameters for the transform function (NULL when transform_function is NULL)"/>
      <constraint xsi:type="primary" referenceId="PRIMARY">
         <column name="id"/>
      </constraint>
      <constraint xsi:type="unique" referenceId="MOOAUTH_ATTR_MAPPING_PROVIDER_ID_ATTR_TYPE">
         <column name="provider_id"/>
         <column name="attribute_type"/>
      </constraint>
      <constraint xsi:type="foreign" referenceId="MOOAUTH_ATTR_MAPPING_PROVIDER_ID_FK"
                  table="m2oidc_oauth_attribute_mappings" column="provider_id"
                  referenceTable="m2oidc_oauth_client_apps" referenceColumn="id"
                  onDelete="CASCADE"/>
   </table>

   <!-- Normalized role/group mapping table (Phase 4).
        One row per provider × mapping_type × OIDC group.
        mapping_type: 'admin_role' or 'customer_group'
        magento_role_id: Magento role ID (admin_role) or customer group ID (customer_group) -->
   <table name="m2oidc_oauth_role_mappings" resource="default" engine="innodb"
          comment="Normalized OIDC role and customer group mappings per provider">
      <column xsi:type="int" name="id" padding="10" unsigned="true" nullable="false"
              identity="true" comment="Row ID"/>
      <column xsi:type="smallint" name="provider_id" padding="7" unsigned="true" nullable="false"
              comment="OIDC Provider ID (FK to m2oidc_oauth_client_apps.id)"/>
      <column xsi:type="varchar" name="mapping_type" length="20" nullable="false"
              comment="admin_role or customer_group"/>
      <column xsi:type="varchar" name="oidc_group" length="255" nullable="false"
              comment="OIDC group/role claim value (case-insensitive match at runtime)"/>
      <column xsi:type="varchar" name="magento_role_id" length="50" nullable="false"
              comment="Magento admin role ID or customer group ID"/>
      <column xsi:type="smallint" name="sort_order" padding="5" unsigned="true" nullable="false"
              default="0" comment="Evaluation order (lower = matched first)"/>
      <constraint xsi:type="primary" referenceId="PRIMARY">
         <column name="id"/>
      </constraint>
      <constraint xsi:type="unique" referenceId="MOOAUTH_ROLE_MAPPING_PROVIDER_ID_TYPE_GROUP">
         <column name="provider_id"/>
         <column name="mapping_type"/>
         <column name="oidc_group"/>
      </constraint>
      <constraint xsi:type="foreign" referenceId="MOOAUTH_ROLE_MAPPING_PROVIDER_ID_FK"
                  table="m2oidc_oauth_role_mappings" column="provider_id"
                  referenceTable="m2oidc_oauth_client_apps" referenceColumn="id"
                  onDelete="CASCADE"/>
      <index referenceId="MOOAUTH_ROLE_MAPPING_PROVIDER_ID_TYPE" indexType="btree">
         <column name="provider_id"/>
         <column name="mapping_type"/>
      </index>
   </table>

   <!-- Tracks which OIDC provider created each Magento user (customer or admin) -->
   <table name="m2oidc_oauth_user_provider" resource="default" engine="innodb"
          comment="Tracks which OIDC provider created each Magento user">
      <column xsi:type="int" name="id" padding="10" unsigned="true" nullable="false"
              identity="true" comment="ID"/>
      <column xsi:type="varchar" name="user_type" nullable="false" length="10"
              comment="User type: customer or admin"/>
      <column xsi:type="int" name="user_id" padding="10" unsigned="true" nullable="false"
              comment="Magento user ID (customer entity_id or admin user_id)"/>
      <column xsi:type="smallint" name="provider_id" padding="7" unsigned="true" nullable="false"
              comment="OIDC Provider ID (references m2oidc_oauth_client_apps.id)"/>
      <column xsi:type="timestamp" name="created_at" nullable="false"
              default="CURRENT_TIMESTAMP" comment="Timestamp when the user was created via OIDC"/>
      <constraint xsi:type="primary" referenceId="PRIMARY">
         <column name="id"/>
      </constraint>
      <constraint xsi:type="unique" referenceId="MOOAUTH_USER_PROVIDER_TYPE_USER_ID">
         <column name="user_type"/>
         <column name="user_id"/>
      </constraint>
      <index referenceId="MOOAUTH_USER_PROVIDER_PROVIDER_ID" indexType="btree">
         <column name="provider_id"/>
      </index>
   </table>
</schema>