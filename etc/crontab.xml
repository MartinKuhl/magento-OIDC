<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <!-- Clean up the OIDC debug log file daily: disable logging and delete file when older than 7 days -->
        <job name="m2oidc_log_rotation" instance="M2Oidc\OAuth\Cron\LogCleanup" method="execute">
            <schedule>0 3 * * *</schedule>
        </job>

        <!-- Re-fetch OIDC discovery documents every 6 hours so endpoints stay up-to-date
             without requiring a manual provider save.  Only changed fields are written to DB. -->
        <job name="m2oidc_refresh_oidc_discovery"
             instance="M2Oidc\OAuth\Cron\RefreshOidcDiscovery"
             method="execute">
            <schedule>0 */6 * * *</schedule>
        </job>

        <!-- Fire a webhook alert after N consecutive IdP reachability-check failures (per
             provider, via health_alert_webhook_url / health_alert_failure_threshold). Runs
             every 5 minutes — far tighter than the 6h discovery-refresh cadence above, since
             this cron exists specifically for fast outage detection. No-op for any provider
             that hasn't set a failure threshold and webhook URL. -->
        <job name="m2oidc_health_check_alert"
             instance="M2Oidc\OAuth\Cron\HealthCheckAlert"
             method="execute">
            <schedule>*/5 * * * *</schedule>
        </job>
    </group>
</config>
