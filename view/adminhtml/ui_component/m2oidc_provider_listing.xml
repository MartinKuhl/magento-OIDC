<?xml version="1.0" encoding="UTF-8"?>
<!--
    UI Grid component definition for the OIDC Provider management list.
    Data source: m2oidc_oauth_client_apps table via Collection.
    Route: m2oidc/provider/index
-->
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">
                m2oidc_provider_listing.m2oidc_provider_listing_data_source
            </item>
        </item>
    </argument>

    <settings>
        <buttons>
            <button name="add">
                <url path="m2oidc/provider/edit"/>
                <class>primary</class>
                <label translate="true">Add New Provider</label>
            </button>
        </buttons>
        <spinner>m2oidc_provider_columns</spinner>
        <deps>
            <dep>m2oidc_provider_listing.m2oidc_provider_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="m2oidc_provider_listing_data_source"
                component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>M2Oidc_OAuth::oauth_settings</aclResource>
        <dataProvider class="MooauthProviderListingDataProvider"
                      name="m2oidc_provider_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="m2oidc_provider_columns">

        <column name="id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>

        <column name="display_name" component="Magento_Ui/js/grid/columns/link">
            <settings>
                <filter>text</filter>
                <label translate="true">Provider Name</label>
            </settings>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="link" xsi:type="string">edit_url</item>
                </item>
            </argument>
        </column>

        <column name="login_type">
            <settings>
                <filter>text</filter>
                <label translate="true">Login Type</label>
            </settings>
        </column>

        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Status</label>
            </settings>
        </column>

        <column name="sort_order">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Sort Order</label>
            </settings>
        </column>

        <!-- Test-Status: success / failed as filterable select dropdown -->
        <column name="last_test_status" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="M2Oidc\OAuth\Ui\Component\Listing\Column\TestStatusOptions"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Test Status</label>
                <sortable>true</sortable>
            </settings>
        </column>

        <!-- Last tested timestamp with date-range filter -->
        <column name="last_test_at"
                class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <label translate="true">Last Tested</label>
                <dataType>date</dataType>
                <sortable>true</sortable>
            </settings>
        </column>

        <!-- Active Admin Users: live count via JOIN on admin_user -->
        <column name="active_admin_users"
                class="M2Oidc\OAuth\Ui\Component\Listing\Column\ActiveUserCount">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="user_type" xsi:type="string">admin</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Active Admin Users</label>
                <sortable>false</sortable>
            </settings>
        </column>

        <!-- Active Customers: live count via JOIN on customer_entity -->
        <column name="active_customers"
                class="M2Oidc\OAuth\Ui\Component\Listing\Column\ActiveUserCount">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="user_type" xsi:type="string">customer</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Active Customers</label>
                <sortable>false</sortable>
            </settings>
        </column>

        <!-- PKCE method badge: S256 / plain / disabled -->
        <column name="pkce_status"
                class="M2Oidc\OAuth\Ui\Component\Listing\Column\PkceStatus">
            <settings>
                <label translate="true">PKCE</label>
                <sortable>false</sortable>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>

        <!-- JWKS endpoint: configured / not set -->
        <column name="jwks_status"
                class="M2Oidc\OAuth\Ui\Component\Listing\Column\JwksStatus">
            <settings>
                <label translate="true">JWKS</label>
                <sortable>false</sortable>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>

        <actionsColumn name="actions"
                       class="M2Oidc\OAuth\Ui\Component\Listing\Column\Actions"
                       component="M2Oidc_OAuth/js/grid/columns/provider-actions">
            <settings>
                <indexField>id</indexField>
                <label translate="true">Actions</label>
                <sortOrder>200</sortOrder>
            </settings>
        </actionsColumn>

    </columns>

</listing>
