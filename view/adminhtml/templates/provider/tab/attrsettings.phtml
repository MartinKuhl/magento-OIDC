<script>
(function () {
    // Dynamic role mapping rows
    var roleContainer = document.getElementById('m2oidc-role-mappings');
    var addRoleBtn    = document.getElementById('m2oidc-add-mapping');
    if (addRoleBtn && roleContainer) {
        var roleIndex = roleContainer.querySelectorAll('.m2oidc-mapping-row').length;
        addRoleBtn.addEventListener('click', function () {
            var row = roleContainer.querySelector('.m2oidc-mapping-row');
            if (!row) { return; }
            var clone = row.cloneNode(true);
            clone.querySelectorAll('input, select').forEach(function (el) {
                el.name = el.name.replace(/\[\d+\]/, '[' + roleIndex + ']');
                el.value = '';
            });
            clone.querySelector('select').selectedIndex = 0;
            roleContainer.appendChild(clone);
            roleIndex++;
        });
        roleContainer.addEventListener('click', function (e) {
            if (e.target.classList.contains('m2oidc-remove-mapping')) {
                var rows = roleContainer.querySelectorAll('.m2oidc-mapping-row');
                if (rows.length > 1) { e.target.closest('.m2oidc-mapping-row').remove(); }
            }
        });
    }

    // Dynamic customer group mapping rows
    var cgmContainer = document.getElementById('m2oidc-customer-group-mappings');
    var addCgmBtn    = document.getElementById('m2oidc-add-cgm');
    if (addCgmBtn && cgmContainer) {
        var cgmIndex = cgmContainer.querySelectorAll('.m2oidc-cgm-row').length;
        addCgmBtn.addEventListener('click', function () {
            var row = cgmContainer.querySelector('.m2oidc-cgm-row');
            if (!row) { return; }
            var clone = row.cloneNode(true);
            clone.querySelectorAll('input, select').forEach(function (el) {
                el.name = el.name.replace(/\[\d+\]/, '[' + cgmIndex + ']');
                el.value = '';
            });
            clone.querySelector('select').selectedIndex = 0;
            cgmContainer.appendChild(clone);
            cgmIndex++;
        });
        cgmContainer.addEventListener('click', function (e) {
            if (e.target.classList.contains('m2oidc-remove-cgm')) {
                var rows = cgmContainer.querySelectorAll('.m2oidc-cgm-row');
                if (rows.length > 1) { e.target.closest('.m2oidc-cgm-row').remove(); }
            }
        });
    }

    // Disable only the Role Mappings and Group Mappings rows when Group / Role Claim is empty.
    // Default Admin Role, Default Customer Group, and section headers remain always active.
    var groupAttrInput  = document.getElementById('group_attribute');
    var roleMappingRow  = document.getElementById('m2oidc-role-mappings-row');
    var cgmMappingRow   = document.getElementById('m2oidc-cgm-mappings-row');

    function syncGroupMappingSections() {
        var isEmpty = !groupAttrInput || groupAttrInput.value.trim() === '';
        [roleMappingRow, cgmMappingRow].forEach(function (row) {
            if (!row) { return; }
            row.style.opacity       = isEmpty ? '0.4' : '';
            row.style.pointerEvents = isEmpty ? 'none' : '';
            row.querySelectorAll('input, select, button').forEach(function (el) {
                el.disabled = isEmpty;
            });
        });
    }

    if (groupAttrInput) {
        groupAttrInput.addEventListener('input', syncGroupMappingSections);
        syncGroupMappingSections();
    }
}());
</script>
