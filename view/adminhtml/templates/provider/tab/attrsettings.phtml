<script>
(function () {
    'use strict';

    var rolesHtml = <?= /* @noEscape */ json_encode(
        array_reduce(
            $roles,
            static function (string $carry, array $role) use ($escaper): string {
                return $carry
                    . '<option value="' . $escaper->escapeHtmlAttr($role['value']) . '">'
                    . $escaper->escapeHtml($role['label'])
                    . '</option>';
            },
            '<option value="">-- ' . $escaper->escapeHtml(__('Select Role')) . ' --</option>'
        )
    ) ?>;

    var mappingIndex = <?= count($roleMappings) > 0 ? count($roleMappings) : 1 ?>;

    document.getElementById('mooauth-add-mapping').addEventListener('click', function () {
        var container = document.getElementById('mooauth-role-mappings');
        var row = document.createElement('div');
        row.className = 'mooauth-mapping-row';
        row.style.cssText = 'margin-bottom:8px; display:flex; align-items:center;';
        row.innerHTML =
            '<input type="text" name="oauth_role_mapping[' + mappingIndex + '][group]"'
            + ' placeholder="OIDC Group Name" class="admin__control-text" style="width:200px;">'
            + '<span style="margin:0 10px;">&rarr;</span>'
            + '<select name="oauth_role_mapping[' + mappingIndex + '][role]"'
            + ' class="admin__control-select" style="width:220px;">' + rolesHtml + '</select>'
            + '<button type="button" class="action-delete mooauth-remove-mapping"'
            + ' style="margin-left:10px;"><?= $escaper->escapeJs(__('Remove')) ?></button>';
        container.appendChild(row);
        mappingIndex++;
        bindRemove(row.querySelector('.mooauth-remove-mapping'));
    });

    function bindRemove(btn) {
        btn.addEventListener('click', function () {
            var container = document.getElementById('mooauth-role-mappings');
            var rows = container.querySelectorAll('.mooauth-mapping-row');
            if (rows.length > 1) {
                btn.parentElement.remove();
            } else {
                btn.parentElement.querySelector('input').value = '';
                btn.parentElement.querySelector('select').selectedIndex = 0;
            }
        });
    }

    document.querySelectorAll('.mooauth-remove-mapping').forEach(bindRemove);
}());
</script>
