<script>
(function () {
    'use strict';

    function bindOidcDependency(showId, restrictId) {
        var showCb    = document.getElementById(showId);
        var restrictCb = document.getElementById(restrictId);
        if (!showCb || !restrictCb) {
            return;
        }

        function syncState() {
            if (!showCb.checked) {
                restrictCb.checked  = false;
                restrictCb.disabled = true;
            } else {
                restrictCb.disabled = false;
            }
        }

        showCb.addEventListener('change', syncState);
        syncState();
    }

    document.addEventListener('DOMContentLoaded', function () {
        bindOidcDependency('loginopt_show_admin_link', 'loginopt_disable_admin');
        bindOidcDependency('loginopt_show_customer_link', 'loginopt_disable_customer');
    });
}());
</script>
