<script>
(function () {
    'use strict';

    var autoRedirectAllowed = <?= $autoRedirectAllowed ? 'true' : 'false' ?>;
    var hasOidcAdmins       = <?= $hasOidcAdmins    ? 'true' : 'false' ?>;
    var hasOidcCustomers    = <?= $hasOidcCustomers ? 'true' : 'false' ?>;

    /**
     * Parent → child dependency: child is enabled only when parent is checked
     * and an optional extra condition is met.
     */
    function bindDependency(parentId, childId, extraCondition) {
        var parent = document.getElementById(parentId);
        var child  = document.getElementById(childId);
        if (!parent || !child) { return; }

        function sync() {
            var allowed = parent.checked && (typeof extraCondition === 'undefined' || extraCondition);
            child.disabled = !allowed;
            if (!allowed) { child.checked = false; }
        }

        parent.addEventListener('change', sync);
        sync();
    }

    document.addEventListener('DOMContentLoaded', function () {
        // SSO button → Disable non-OIDC (also gated by whether any OIDC users exist)
        bindDependency('loginopt_show_admin_link',    'loginopt_disable_admin',    hasOidcAdmins);
        bindDependency('loginopt_show_customer_link', 'loginopt_disable_customer', hasOidcCustomers);

        // Disable non-OIDC → Auto Redirect (+ provider-count gate)
        bindDependency('loginopt_disable_admin',    'loginopt_autoredirect_admin',    autoRedirectAllowed);
        bindDependency('loginopt_disable_customer', 'loginopt_autoredirect_customer', autoRedirectAllowed);

        // Cascade: unchecking SSO button re-evaluates the full chain
        ['loginopt_show_admin_link', 'loginopt_show_customer_link'].forEach(function (id) {
            document.getElementById(id)?.addEventListener('change', function () {
                var evt = new Event('change');
                document.getElementById('loginopt_disable_admin')?.dispatchEvent(evt);
                document.getElementById('loginopt_disable_customer')?.dispatchEvent(evt);
            });
        });
    });
}());
</script>

