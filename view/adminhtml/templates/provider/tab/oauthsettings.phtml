<script>
(function () {
    document.addEventListener('DOMContentLoaded', function () {
        // Fix: Magento's Widget.Tabs renders tab content inside <li> elements.
        // jQuery UI's _tabKeydown handler is bound to those <li> elements and
        // calls event.preventDefault() for Space and arrow keys, which breaks
        // normal text-input behaviour (typing spaces, moving the cursor).
        // Stopping propagation at the content-div level prevents the event
        // from ever reaching the <li> handler.
        document.querySelectorAll(
            '#m2oidc_provider_tabs li > div[id$="_content"]'
        ).forEach(function (div) {
            div.addEventListener('keydown', function (e) {
                e.stopPropagation();
            });
        });

        // Toggle client_secret required based on public_client checkbox.
        // In edit mode the secret is never required (leave blank = keep existing).
        var isEditMode          = <?= $isEditMode ? 'true' : 'false' ?>;
        var publicClientCb      = document.getElementById('public_client');
        var secretInput         = document.getElementById('client_secret');
        var secretRequiredMark  = document.getElementById('client_secret_required_mark');

        function updateSecretRequired() {
            if (!secretInput) { return; }
            var requireSecret = !isEditMode && publicClientCb && !publicClientCb.checked;
            if (requireSecret) {
                secretInput.setAttribute('required', 'required');
                if (secretRequiredMark) { secretRequiredMark.style.display = ''; }
            } else {
                secretInput.removeAttribute('required');
                if (secretRequiredMark) { secretRequiredMark.style.display = 'none'; }
            }
        }

        var sendCredentialsRow  = document.getElementById('send_credentials_row');
        var headerCb            = document.getElementById('values_in_header');
        var bodyCb              = document.getElementById('values_in_body');

        function updateSendCredentials() {
            if (!sendCredentialsRow) { return; }
            if (publicClientCb && publicClientCb.checked) {
                sendCredentialsRow.style.opacity       = '0.4';
                sendCredentialsRow.style.pointerEvents = 'none';
                if (headerCb) { headerCb.checked = false; }
                if (bodyCb)   { bodyCb.checked   = false; }
            } else {
                sendCredentialsRow.style.opacity       = '';
                sendCredentialsRow.style.pointerEvents = '';
            }
        }

        if (publicClientCb) {
            publicClientCb.addEventListener('change', updateSecretRequired);
            publicClientCb.addEventListener('change', updateSendCredentials);
        }
        updateSecretRequired();
        updateSendCredentials();
    });
}());
</script>
