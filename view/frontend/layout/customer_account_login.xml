<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <block class="M2Oidc\OAuth\Block\OAuth" 
                name="m2oidc.oauth.customer.link" 
                template="customerssobutton.phtml">
                <arguments>
                    <argument name="oidc_visibility" xsi:type="object">
                        M2Oidc\OAuth\ViewModel\OidcLoginVisibility
                    </argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
