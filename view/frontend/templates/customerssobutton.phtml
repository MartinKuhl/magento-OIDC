    <?php
    /**
     * Multi-provider SSO button loop.
     *
     * Filters by show_customer_link so only providers that have the flag
     * enabled in loginoptions.phtml are rendered.
     */
    $activeProviders = $block->getActiveProviders('customer');
    $activeProviders = array_filter(
        $activeProviders,
        fn($p) => (int) ($p['show_customer_link'] ?? 0) === 1
    );
    ?>
    <?php if (!empty($activeProviders)): ?>
<div class="sso-button-container sso-button-container--multi">
        <?php foreach ($activeProviders as $provider):
            $pid      = (int) ($provider['id'] ?? 0);
            $name     = $escaper->escapeHtml($provider['display_name'] ?? $provider['app_name'] ?? '');
            $label    = $escaper->escapeHtml(
                !empty($provider['button_label'])
                ? $provider['button_label']
                : __('Login with %1', $name)
            );
            $color    = preg_match('/^#[0-9a-fA-F]{6}$/', (string) ($provider['button_color'] ?? ''))
            ? $escaper->escapeHtmlAttr($provider['button_color'])
            : '#0066cc';
            $url      = $escaper->escapeUrl($block->getSPInitiatedUrlForProvider($pid));
            ?>
    <a class="sso-button sso-button--provider"
       href="<?= $url /* @noEscape */ ?>"
       style="background-color: <?= $color /* @noEscape */ ?>;"
       aria-label="<?= $escaper->escapeHtmlAttr(__('Sign in with %1', $name)) ?>">
            <?= $label /* @noEscape */ ?>
    </a>
    <?php endforeach; ?>
</div>
    <?php endif; ?>

