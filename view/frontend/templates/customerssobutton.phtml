<script>
(function() {
    'use strict';

    // Hide password login fields when OIDC-only mode enabled
    function hidePasswordFields() {
        var loginBlock = document.querySelector('.block-customer-login')
            || document.querySelector('.login-container')
            || document.querySelector('body');

        if (!loginBlock) {
            return;
        }

        // Hide form elements
        var loginForm = loginBlock.querySelector('form.form-login');
        if (loginForm) {
            loginForm.style.display = 'none';
        }

        var fieldsets = loginBlock.querySelectorAll(
            'fieldset.login, fieldset.fieldset.login'
        );
        fieldsets.forEach(function(fieldset) {
            fieldset.style.display = 'none';
        });

        // Hide demo box and any parent containers
        var allElements = loginBlock.querySelectorAll('*');
        allElements.forEach(function(el) {
            var text = (el.textContent || '').trim();
            var shortText = text.substring(0, 100);
            if (shortText.includes('Try Demo') ||
                shortText.includes('Demo Customer')) {
                el.style.display = 'none';
                if (el.parentElement) {
                    el.parentElement.style.display = 'none';
                }
                if (el.parentElement && el.parentElement.parentElement) {
                    var grandparent = el.parentElement.parentElement;
                    if (!grandparent.classList.contains('block-customer-login')) {
                        grandparent.style.display = 'none';
                    }
                }
            }

            // Hide OR divider
            if (text === 'OR' || text === 'or') {
                el.style.display = 'none';
                if (el.previousElementSibling) {
                    el.previousElementSibling.style.display = 'none';
                }
                if (el.nextElementSibling) {
                    el.nextElementSibling.style.display = 'none';
                }
            }
        });

        // Update header text
        var headerText = loginBlock.querySelector('.block-title strong');
        if (headerText) {
            headerText.textContent = 'Please sign in with OIDC';
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', hidePasswordFields);
    } else {
        hidePasswordFields();
    }
})();
</script>
<?php endif; ?>
