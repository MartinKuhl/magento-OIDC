includes:
    - phpstan.neon
    - phar:///var/www/html/vendor/phpstan/phpstan/phpstan.phar/conf/bleedingEdge.neon

parameters:
    treatPhpDocTypesAsCertain: false
    magento:
        magentoRoot: ../..  # Points to /var/www/html from module directory
    stubFiles:
        # Overrides auto-generated FactoryAutoloader stubs for classes whose names
        # end with "Factory" but are NOT simple Magento DI factories.
        - phpstan-stubs.stub
    excludePaths:
        analyseAndScan:
            - .github
            # Stub file defines minimal Magento class skeletons for CI-only use;
            # scanning it would override PHPStan's real Magento type knowledge.
            - Test/Stubs
        analyse:
            - psalm-stubs.stub
            - phpstan-stubs.stub
