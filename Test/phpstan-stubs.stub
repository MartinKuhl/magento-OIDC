<?php
/**
 * PHPStan stubs for Magento classes whose names end with "Factory".
 *
 * The bitexpert/phpstan-magento FactoryAutoloader generates minimal stubs
 * (only create(array $data = [])) for ANY class ending with "Factory".
 * The classes below are NOT simple Magento DI factories, so we override
 * those generated stubs here via phpstan.local.neon's stubFiles directive,
 * which takes precedence over everything the autoloader generates.
 */

