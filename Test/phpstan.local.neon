includes:
    - phpstan.neon
    - phar:///var/www/html/vendor/phpstan/phpstan/phpstan.phar/conf/bleedingEdge.neon

parameters:
    treatPhpDocTypesAsCertain: false
    magento:
        magentoRoot: ../../..  # Points to /var/www/html from Test/ subdirectory
    excludePaths:
        analyseAndScan:
            - ../.github
            # Stub file defines minimal Magento class skeletons for CI-only use;
            # scanning it would override PHPStan's real Magento type knowledge.
            - Stubs
        analyse:
            - psalm-stubs.stub
            - phpstan-stubs.stub
    ignoreErrors:
        # The bitexpert/phpstan-magento FactoryAutoloader matches ANY class ending with
        # "Factory" and generates a minimal stub (only `create(array $data = [])`) for it.
        # CookieMetadataFactory, ResultFactory, and FileFactory are NOT simple DI factories —
        # they have custom signatures defined in Test/phpstan-stubs.stub. PHPStan 2.x loads
        # the stubs correctly (confirmed via dump-parameters) but the FactoryAutoloader's
        # generated stub still takes precedence in practice. The real methods exist in vendor.
        -
            message: '#Call to an undefined method Magento\\Framework\\Stdlib\\Cookie\\CookieMetadataFactory::(createPublicCookieMetadata|createCookieMetadata|createSensitiveCookieMetadata)\(\)\.#'
            identifier: method.notFound
            reportUnmatched: false
        -
            message: '#Access to undefined constant Magento\\Framework\\Controller\\ResultFactory::TYPE_#'
            identifier: classConstant.notFound
            reportUnmatched: false
        -
            message: '#Method Magento\\Framework\\App\\Response\\Http\\FileFactory::create\(\) invoked with \d+ parameters?, \d+-?\d* required\.#'
            identifier: arguments.count
            reportUnmatched: false
        -
            message: '#Parameter \#1 \$data of method Magento\\Framework\\App\\Response\\Http\\FileFactory::create\(\) expects array, string given\.#'
            identifier: argument.type
            reportUnmatched: false
