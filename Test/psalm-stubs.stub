<?php
/**
 * Psalm & PHPStan Stubs für Magento-generierte Factory-Klassen.
 *
 * Diese Datei wurde deaktiviert (Endung .stub) um Probleme mit dem DI-Scanner
 * zu vermeiden. Für statische Analyse-Tools kann sie bei Bedarf wieder umbenannt
 * oder in separaten Dateien pro Namespace aufgeteilt werden.
 */

// phpcs:ignoreFile

namespace Magento\Framework\App {
    /**
     * Augment RequestInterface with getClientIp() which is defined on the concrete
     * HTTP Request class but missing from the interface declaration.
     */
    interface RequestInterface
    {
        public function getClientIp(bool $checkProxy = true): string;
    }
}

namespace Magento\User\Model {
    class UserFactory
    {
        public function create(array $data = []): \Magento\User\Model\User
        {
            return new \Magento\User\Model\User();
        }
    }
}

namespace Magento\User\Model\ResourceModel\User {
    class CollectionFactory
    {
        public function create(array $data = [])
        {
            return new \Magento\User\Model\ResourceModel\User\Collection();
        }
    }
}

namespace Magento\Customer\Model {
    class CustomerFactory
    {
        public function create(array $data = [])
        {
            return new \Magento\Customer\Model\Customer();
        }
    }
}

namespace Magento\Customer\Api\Data {
    class AddressInterfaceFactory
    {
        public function create(array $data = [])
        {
            return new class implements \Magento\Customer\Api\Data\AddressInterface {};
        }
    }

    interface RegionInterface
    {
        public function setRegion(?string $region): static;
        public function setRegionCode(?string $regionCode): static;
        public function setRegionId(?int $regionId): static;
    }

    class RegionInterfaceFactory
    {
        public function create(array $data = []): RegionInterface
        {
            return new class implements RegionInterface {
                public function setRegion(?string $region): static
                {
                    return $this;
                }
                public function setRegionCode(?string $regionCode): static
                {
                    return $this;
                }
                public function setRegionId(?int $regionId): static
                {
                    return $this;
                }
            };
        }
    }
}

namespace Magento\Framework\Controller\Result {
    class Raw implements \Magento\Framework\Controller\ResultInterface
    {
        public function renderResult(\Magento\Framework\App\ResponseInterface $response): static
        {
            return $this;
        }

        public function setHttpResponseCode(int $code): static
        {
            return $this;
        }

        public function setHeader(string $name, $value, bool $replace = false): static
        {
            return $this;
        }

        public function setContents(string $contents): static
        {
            return $this;
        }
    }

    class RawFactory
    {
        public function create(array $data = []): Raw
        {
            return new Raw();
        }
    }
}

namespace Magento\Integration\Model\Oauth {
    class Token
    {
        public function createCustomerToken(int $customerId): static
        {
            return $this;
        }

        public function getToken(): string
        {
            return '';
        }
    }

    class TokenFactory
    {
        public function create(array $data = []): Token
        {
            return new Token();
        }
    }
}

